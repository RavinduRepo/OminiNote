# Google OAuth credentials — copy to .env and fill in values.
# Get clients from: https://console.cloud.google.com/apis/credentials
# Usage: source .env && flutter run -d linux (or windows/macos)

# Desktop OAuth client (Windows / macOS / Linux) — type: Desktop app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Android OAuth client — type: Android, package com.example.omininote
ANDROID_CLIENT_ID=

# Web OAuth client — type: Web application
WEB_CLIENT_ID=
WEB_CLIENT_SECRET=
