# Google OAuth credentials for desktop platforms
# Get these from: https://console.developers.google.com/
# 1. Create a new OAuth 2.0 Client ID (Desktop application)
# 2. Copy the Client ID and Client Secret below
# 3. Set as environment variables when building:
#    GOOGLE_CLIENT_ID=<your-client-id> GOOGLE_CLIENT_SECRET=<your-secret> flutter run -d windows

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
